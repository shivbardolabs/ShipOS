# BAR-379: Fastlane Configuration for ShipOS iOS
# Lanes: test, beta (TestFlight), release (App Store)

default_platform(:ios)

platform :ios do
  # ─── Before All ──────────────────────────────────
  before_all do
    setup_ci if ENV['CI']
  end

  # ─── Test Lane ───────────────────────────────────
  desc "Run all tests"
  lane :test do
    scan(
      scheme: "ShipOS",
      devices: ["iPhone 15 Pro"],
      clean: true,
      code_coverage: true,
      output_directory: "./build/test-results",
      result_bundle: true
    )
  end

  # ─── Beta Lane (TestFlight) ─────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number using CI run number
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "ShipOS.xcodeproj"
    )

    # Code signing
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      app_identifier: [
        "ai.bardolabs.shipos",
        "ai.bardolabs.shipos.widgets"
      ],
      readonly: is_ci
    )

    # Build
    build_app(
      scheme: "ShipOS",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "ShipOS.ipa",
      include_bitcode: false,
      export_options: {
        provisioningProfiles: {
          "ai.bardolabs.shipos" => "match AppStore ai.bardolabs.shipos",
          "ai.bardolabs.shipos.widgets" => "match AppStore ai.bardolabs.shipos.widgets"
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: changelog_from_git_commits(
        commits_count: 10,
        merge_commit_filtering: "exclude_merges"
      )
    )
  end

  # ─── Release Lane (App Store) ───────────────────
  desc "Build and submit to App Store review"
  lane :release do
    # Ensure we're on a release branch
    ensure_git_branch(branch: "release/*")
    ensure_git_status_clean

    # Version bump
    version = get_version_number(xcodeproj: "ShipOS.xcodeproj", target: "ShipOS")

    # Same build as beta
    beta

    # Submit for review
    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )

    # Tag release
    add_git_tag(tag: "v#{version}")
    push_git_tags
  end

  # ─── Screenshots Lane ──────────────────────────
  desc "Capture App Store screenshots"
  lane :screenshots do
    capture_screenshots(
      scheme: "ShipOSUITests",
      devices: [
        "iPhone 15 Pro Max",
        "iPhone SE (3rd generation)",
        "iPad Pro (12.9-inch) (6th generation)"
      ],
      languages: ["en-US"],
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true
    )
    frame_screenshots(
      silver: true,
      path: "./fastlane/screenshots"
    )
  end

  # ─── Error Handling ────────────────────────────
  error do |lane, exception|
    # Could notify Slack here
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end
